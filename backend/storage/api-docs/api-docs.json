        "/paypal/webhook": {
            "post": {
                "tags": [
                    "Pagos"
                ],
                "summary": "Webhook PayPal para confirmar pago",
                "description": "Endpoint llamado por PayPal cuando el pago se completa",
                "operationId": "19826948639c8df4f04e23de54395741",
                "responses": {
                    "200": {
                        "description": "Pago confirmado y reservas creadas correctamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Pago confirmado y reservas creadas"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Error de validación o pago no completado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Pago no completado"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Error interno del servidor",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Error en webhook"
                                        },
                                        "error": {
                                            "type": "string",
                                            "example": "Mensaje de excepción"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        }
