                                                                "example": "consultor@test.com"
                                                            },
                                                            "telefono": {
                                                                "type": "string",
                                                                "example": "987654321"
                                                            },
                                                            "foto": {
                                                                "type": "string",
                                                                "example": "foto.jpg"
                                                            }
                                                        },
                                                        "type": "object"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "No autenticado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
