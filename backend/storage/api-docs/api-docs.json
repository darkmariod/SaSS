        "/paypal/create-order": {
            "post": {
                "tags": [
                    "Pagos"
                ],
                "summary": "Crear orden de pago en PayPal",
                "operationId": "createPayPalOrder",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "consultant_id",
                                    "date",
                                    "hours"
                                ],
                                "properties": {
                                    "consultant_id": {
                                        "type": "integer",
                                        "example": 5
                                    },
                                    "date": {
                                        "type": "string",
                                        "example": "2024-10-23"
                                    },
                                    "hours": {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
