# =============================================================================
# Docker Ignore — Barber Booking
# =============================================================================
# Excluye archivos innecesarios del contexto de build de Docker.
# Hace el build más rápido y evita filtrados de secretos.
# =============================================================================

# ── Version Control ──
.git
.gitignore
.gitattributes

# ── Environment ──
.env
.env.*
!.env.example

# ── Dependencies (se instalan dentro del build) ──
vendor/
node_modules/

# ── Local dev ──
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Laravel specific ──
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
storage/logs/*
storage/debugbar/*
!storage/framework/cache/data/.gitkeep
!storage/framework/sessions/.gitkeep
!storage/framework/views/.gitkeep
!storage/logs/.gitkeep
public/storage
public/hot

# ── Docker ──
docker-compose*.yml
docker-compose*.yaml

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Tests ──
phpunit.xml
phpunit.xml.dist
tests/

# ── Docs ──
DEPLOY.md
*.md
